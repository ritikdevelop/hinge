<mxfile host="app.diagrams.net"><diagram name="Backend Architecture"><mxGraphModel dx="1600" dy="1000" shadow="1" grid="1"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Hinge Backend Architecture" style="text;fontSize=20;fontStyle=1;align=center;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="0" y="10" width="1200" height="40" as="geometry"/></mxCell><mxCell id="server" value="Express.js Server&#10;api/index.js&#10;PORT: 4000&#10;HTTP + Socket.io" style="rounded=1;html=1;fillColor=#fff2cc;fontStyle=1;fontSize=12;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="400" y="100" width="200" height="100" as="geometry"/></mxCell><mxCell id="cors" value="Middleware&#10;• CORS&#10;• Body Parser&#10;• Express JSON" style="rounded=1;html=1;fillColor=#f0e8ff;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="100" y="260" width="150" height="100" as="geometry"/></mxCell><mxCell id="routes" value="Routes&#10;• /auth (auth.routes.js)&#10;• /user (user.routes.js)" style="rounded=1;html=1;fillColor=#e1d5e7;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="330" y="260" width="180" height="100" as="geometry"/></mxCell><mxCell id="socket" value="Socket.io&#10;utils/socket.js&#10;Real-time Messaging" style="rounded=1;html=1;fillColor=#d5e8d4;fontSize=11;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="590" y="260" width="160" height="100" as="geometry"/></mxCell><mxCell id="db" value="Database&#10;api/db.js&#10;MongoDB Connection" style="rounded=1;html=1;fillColor=#f8cecc;fontStyle=1;fontSize=12;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="820" y="260" width="180" height="100" as="geometry"/></mxCell><mxCell id="authCtrl" value="Auth Controller&#10;controllers/auth.controller.js&#10;• Login&#10;• Register&#10;• OTP Verify" style="rounded=1;html=1;fillColor=#dae8fc;fontSize=10;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="100" y="420" width="150" height="110" as="geometry"/></mxCell><mxCe