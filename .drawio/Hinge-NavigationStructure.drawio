<mxfile host="app.diagrams.net"><diagram name="Navigation Structure"><mxGraphModel dx="1600" dy="1000" shadow="1"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Hinge - Navigation Structure (StackNavigator.js)" style="text;fontSize=20;fontStyle=1;align=center;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="0" y="10" width="1400" height="40" as="geometry"/></mxCell><mxCell id="stack" value="Root Stack Navigator - StackNavigator.js" style="swimlane;fontStyle=1;fillColor=#e1d5e7;fontSize=12;" vertex="1" parent="1"><mxGeometry x="150" y="70" width="1100" height="800" as="geometry"/></mxCell><mxCell id="auth" value="Auth Flow" style="rounded=1;fillColor=#f8cecc;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="200" y="120" width="180" height="60" as="geometry"/></mxCell><mxCell id="authScreens" value="Auth Screens: LoginScreen, BasicInfoScreen, EmailScreen, OtpScreen, PasswordScreen" style="rounded=1;fillColor=#fff2cc;fontSize=9;" vertex="1" parent="1"><mxGeometry x="200" y="210" width="180" height="120" as="geometry"/></mxCell><mxCell id="onboard" value="Onboarding Flow" style="rounded=1;fillColor=#ffe6cc;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="450" y="120" width="180" height="60" as="geometry"/></mxCell><mxCell id="onboardScreens" value="Onboarding Screens: NameScreen, DateOfBirthScreen, LocationScreen, GenderScreen, TypeScreen, DatingTypeScreen, LookingForScreen" style="rounded=1;fillColor=#fff2cc;fontSize=9;" vertex="1" parent="1"><mxGeometry x="450" y="210" width="180" height="140" as="geometry"/></mxCell><mxCell id="onboard2" value="Onboarding Flow (cont.)" style="rounded=1;fillColor=#ffe6cc;fontStyle=1;fontSize=11;" vertex="1" parent="1"><mxGeometry x="700" y="120" width="180" height="60" as="geometry"/></mxCell><mxCell id="onboardScreens2" value="More Onboarding: HomeTownScreen, JobTitleScreen, WorkplaceScreen, PhotoScreen, PromptsScreen, WritePromptScreen, PreFinalScreen" style="rounded=1;f