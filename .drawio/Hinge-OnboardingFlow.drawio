<mxfile host="app.diagrams.net"><diagram name="Onboarding Flow"><mxGraphModel dx="1800" dy="1000" grid="1" shadow="1"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Hinge - Complete Onboarding User Flow" style="text;fontSize=20;fontStyle=1;align=center;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="0" y="10" width="1400" height="40" as="geometry"/></mxCell><mxCell id="phase1" value="PHASE 1: Authentication" style="text;align=center;fontSize=12;fontStyle=1;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="50" y="70" width="350" height="30" as="geometry"/></mxCell><mxCell id="login" value="LoginScreen" style="rounded=1;html=1;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="50" y="120" width="100" height="60" as="geometry"/></mxCell><mxCell id="basic" value="BasicInfoScreen" style="rounded=1;html=1;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="200" y="120" width="100" height="60" as="geometry"/></mxCell><mxCell id="email" value="EmailScreen" style="rounded=1;html=1;fillColor=#fff2cc;" vertex="1" parent="1"><mxGeometry x="350" y="120" width="100" height="60" as="geometry"/></mxCell><mxCell id="phase2" value="PHASE 2: Email Verification" style="text;fontSize=12;fontStyle=1;fillColor=#dae8fc;" vertex="1" parent="1"><mxGeometry x="50" y="210" width="350" height="30" as="geometry"/></mxCell><mxCell id="otp" value="OtpScreen" style="rounded=1;html=1;fillColor=#dae8fc;" vertex="1" parent="1"><mxGeometry x="50" y="260" width="100" height="60" as="geometry"/></mxCell><mxCell id="pass" value="PasswordScreen" style="rounded=1;html=1;fillColor=#dae8fc;" vertex="1" parent="1"><mxGeometry x="200" y="260" width="100" height="60" as="geometry"/></mxCell><mxCell id="phase3" value="PHASE 3: Personal Info" style="text;fontSize=12;fontStyle=1;fillColor=#d5e8d4;" vertex="1" parent="1"><mxGeometry x="500" y="70" width="450" height="30" as="geometry"/></mxCell><mxCell id="name" value="NameScreen" style="rounded=1;html=1;fillCol