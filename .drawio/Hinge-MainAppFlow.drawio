<mxfile host="app.diagrams.net"><diagram name="Main App Flow"><mxGraphModel dx="1600" dy="1000" shadow="1"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="title" value="Hinge - Main App Flow (Post-Onboarding)" style="text;fontSize=20;fontStyle=1;align=center;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="0" y="10" width="1200" height="40" as="geometry"/></mxCell><mxCell id="tab" value="Bottom Tab Navigation" style="text;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="50" y="80" width="900" height="30" as="geometry"/></mxCell><mxCell id="home" value="HomeScreen&#10;icon: shuffle&#10;Discover Matches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;fontSize=11;" vertex="1" parent="1"><mxGeometry x="80" y="130" width="120" height="90" as="geometry"/></mxCell><mxCell id="likes" value="LikesScreen&#10;icon: heart&#10;View Likes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;fontSize=11;" vertex="1" parent="1"><mxGeometry x="250" y="130" width="120" height="90" as="geometry"/></mxCell><mxCell id="chat" value="ChatScreen&#10;icon: chat&#10;Messages List" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="130" width="120" height="90" as="geometry"/></mxCell><mxCell id="prof" value="ProfileScreen&#10;icon: user&#10;User Profile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;fontSize=11;" vertex="1" parent="1"><mxGeometry x="590" y="130" width="120" height="90" as="geometry"/></mxCell><mxCell id="modal" value="Modal Screens" style="text;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="50" y="280" width="900" height="25" as="geometry"/></mxCell><mxCell id="sendlike" value="SendLikeScreen&#10;Send Like Action" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;fontSize=10;" vertex="1" parent="1"><mxGeometry x="80" y="330" width="120" height="80" as="geometry"/></mxCell><mxCell id="handlelike" value="HandleLikeScreen&#10;Accept/Reject Like" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;fontSize=10;" vertex="1" parent="1"><mxGeometry x="250" y="330" width="120" height="80" as="geometry"/></mxCell><mxCell id="chatroom" value="ChatRoomScreen&#10;Messaging Interface&#10;Socket.io" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;fontSize=10;" vertex="1" parent="1"><mxGeometry x="420" y="330" width="120" height="80" as="geometry"/></mxCell><mxCell id="profdets" value="ProfileDetailsScreen&#10;Full Profile View" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;fontSize=10;" vertex="1" parent="1"><mxGeometry x="590" y="330" width="120" height="80" as="geometry"/></mxCell><mxCell id="subs" value="SubscriptionScreen&#10;HingePlus/HingeX" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;fontSize=10;" vertex="1" parent="1"><mxGeometry x="760" y="330" width="120" height="80" as="geometry"/></mxCell><mxCell id="flowT" value="Flow Actions" style="text;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1"><mxGeometry x="50" y="460" width="900" height="25" as="geometry"/></mxCell><mxCell id="flow1" style="endArrow=block;dashed=1;html=1;strokeWidth=2;" edge="1" parent="1" source="home" target="sendlike"><mxGeometry relative="1" as="geometry"><mxPoint x="140" y="310" as="sourcePoint"/></mxGeometry></mxCell><mxCell id="flow1Label" value="Send Like" style="text;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="95" y="265" width="60" height="25" as="geometry"/></mxCell><mxCell id="flow2" style="endArrow=block;dashed=1;html=1;strokeWidth=2;" edge="1" parent="1" source="likes" target="handlelike"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="flow2Label" value="Handle Like" style="text;html=1;fontSize=10;" vertex="1" parent="1"><mxGeometry x="265" y="265" width="70" height="25" as="geometry"/></mxCell><mxCell id="flow3" style="endArrow=block;dashed=1;html=1;strokeWidth=2;" edge="1" parent="1" source="chat" target=